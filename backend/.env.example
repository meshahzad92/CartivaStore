# ─── Database ─────────────────────────────────────────────
DATABASE_URL=sqlite:///./cartiva_store.db

# ─── CORS ─────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173

# ─── App ──────────────────────────────────────────────────
APP_NAME=Cartiva Store API
APP_VERSION=1.0.0
DEBUG=False

# ─── Admin Auth ───────────────────────────────────────────
# REQUIRED — Set strong values before deploying!
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
SECRET_KEY=CHANGE_ME_RANDOM_SECRET_KEY_32_CHARS_MIN

# ─── PostEx Courier API ────────────────────────────────────
# Optional: can also be set from Admin → Settings UI (stored in DB)
POSTEX_API_KEY=
POSTEX_BASE_URL=https://api.postex.pk/services/integration/api/order/v3
